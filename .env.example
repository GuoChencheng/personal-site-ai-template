# AI assistant provider settings
# Supported values: openai, deepseek, or another OpenAI-compatible provider name.
AI_PROVIDER=openai

# OpenAI-compatible chat completions base URL.
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
AI_BASE_URL=https://api.openai.com/v1

# Model name for the selected provider.
AI_MODEL=gpt-4o-mini

# The env var name that contains the API key. Defaults to AI_API_KEY.
AI_API_KEY_ENV=AI_API_KEY

# Put the actual secret in a local .env file, never in source control.
AI_API_KEY=

# Optional request timeout in milliseconds.
AI_TIMEOUT_MS=20000

# Owner/editor controls. Do not prefix these with NEXT_PUBLIC_.
# In production, /editor is hidden unless EDITOR_ENABLED=true and ADMIN_PUBLISH_TOKEN is set.
EDITOR_ENABLED=false
ADMIN_PUBLISH_TOKEN=

# Optional protected publish/deploy workflow. These are read only on the server.
PUBLISH_ENABLED=false
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
CONTENT_FILE_PATH=content/generated/site-content.json
VERCEL_DEPLOY_HOOK_URL=
